<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hospital_doctor_own_tasks_rule" model="ir.rule">
        <field name="name">Doctors: See Own Clinical Tasks Only</field>
        <field name="model_id" ref="project.model_project_task"/>
        <field name="groups" eval="[(4, ref('group_hospital_doctor'))]"/>
        <field name="domain_force">[('user_ids', 'in', user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="hospital_manager_all_tasks_rule" model="ir.rule">
        <field name="name">Medical Manager: See All Clinical Tasks</field>
        <field name="model_id" ref="project.model_project_task"/>
        <field name="groups" eval="[(4, ref('group_hospital_medical_ops_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <record id="hospital_non_clinical_task_rule" model="ir.rule">
        <field name="name">Non-Clinical Users: Restrict from Patient/Clinical Tasks</field>
        <field name="model_id" ref="project.model_project_task"/>
        <field name="groups" eval="[(4, ref('group_hospital_maintenance_tech')), (4, ref('group_hospital_procurement_manager'))]"/>
        <field name="domain_force">['|', ('user_ids', 'in', user.id), ('message_partner_ids', 'in', user.partner_id.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

</odoo>