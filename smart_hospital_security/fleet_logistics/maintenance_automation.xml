<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="pm_ventilator_alpha" model="maintenance.request">
            <field name="name">Monthly Calibration: Portable Ventilator</field>
            <field name="equipment_id" ref="equipment_ventilator_alpha"/>
            <field name="maintenance_type">preventive</field>
            <field name="schedule_date" eval="DateTime.now() + timedelta(days=30)"/>
            <field name="duration">2.0</field>
            <field name="description">Mandatory monthly calibration cycle for life support equipment to ensure field reliability.</field>
        </record>

        <record id="pm_xray_alpha" model="maintenance.request">
            <field name="name">Monthly Calibration: Mobile X-Ray</field>
            <field name="equipment_id" ref="equipment_xray_alpha"/>
            <field name="maintenance_type">preventive</field>
            <field name="schedule_date" eval="DateTime.now() + timedelta(days=30)"/>
            <field name="description">Mandatory monthly calibration cycle for diagnostic imaging to prevent field failure.</field>
        </record>

        <record id="pm_monitor_beta" model="maintenance.request">
            <field name="name">Monthly Calibration: Vital Sign Monitor</field>
            <field name="equipment_id" ref="equipment_monitor_beta"/>
            <field name="maintenance_type">preventive</field>
            <field name="schedule_date" eval="DateTime.now() + timedelta(days=30)"/>
            <field name="description">Mandatory monthly calibration cycle for physiological monitoring dashboard.</field>
        </record>
    </data>
</odoo>