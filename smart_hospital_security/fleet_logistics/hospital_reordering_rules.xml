<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <record id="product_medical_saline" model="product.product">
            <field name="name">Medical Saline Solution (Carton)</field>
        </record>

        <record id="location_unit_alpha_virtual" model="stock.location">
            <field name="name">Mobile Unit Alpha Stock</field>
            <field name="usage">internal</field>
        </record>

        <record id="location_unit_beta_virtual" model="stock.location">
            <field name="name">Mobile Unit Beta Stock</field>
            <field name="usage">internal</field>
        </record>

        <record id="rule_replenish_alpha_saline" model="stock.warehouse.orderpoint">
            <field name="name">Replenish Saline - Unit Alpha</field>
            <field name="location_id" ref="location_unit_alpha_virtual"/>
            <field name="product_id" ref="product_medical_saline"/>
            <field name="product_min_qty">10.0</field>
            <field name="product_max_qty">50.0</field>
        </record>

        <record id="rule_replenish_beta_saline" model="stock.warehouse.orderpoint">
            <field name="name">Replenish Saline - Unit Beta</field>
            <field name="location_id" ref="location_unit_beta_virtual"/>
            <field name="product_id" ref="product_medical_saline"/>
            <field name="product_min_qty">10.0</field>
            <field name="product_max_qty">50.0</field>
        </record>

    </data>
</odoo>