<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="vendor_medical_supplies" model="res.partner">
            <field name="name">Medical Supplies Co</field>
            <field name="supplier_rank" eval="1"/>
        </record>

        <record id="auto_po_epinephrine" model="purchase.order">
            <field name="partner_id" ref="vendor_medical_supplies"/> 
            <field name="order_line" eval="[(0, 0, {
                'product_id': ref('smart_hospital_security.product_epinephrine'),
                'product_qty': 100,
                'price_unit': 10.0,
            })]"/>
        </record>

        <function model="purchase.order" name="button_confirm" eval="([ref('auto_po_epinephrine')],)"/>
    </data>
</odoo>